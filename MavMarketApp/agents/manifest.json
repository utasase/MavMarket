{
  "version": "1.0.0",
  "project": "Mav Market",
  "createdAt": "2026-03-23",
  "defaults": {
    "client": "Expo managed React Native with expo-router",
    "backend": "Supabase",
    "platformScope": [
      "ios",
      "android"
    ],
    "authModel": "UTA email/password with domain enforcement",
    "messaging": "Supabase realtime chat",
    "payments": "Deferred from v1 product scope",
    "securityPosture": "Production-ready baseline"
  },
  "directories": {
    "specs": "agents/specs",
    "templates": "agents/templates",
    "runbooks": "agents/runbooks",
    "tools": "agents/tools"
  },
  "executionOrder": [
    "orchestrator-agent",
    "backend-schema-agent",
    "security-agent",
    "mobile-foundation-agent",
    "auth-agent",
    "marketplace-agent",
    "messaging-agent",
    "profile-trust-agent",
    "moderation-admin-agent",
    "platform-release-agent",
    "payment-architecture-agent"
  ],
  "agents": [
    {
      "id": "orchestrator-agent",
      "name": "Orchestrator Agent",
      "phase": 1,
      "spec": "agents/specs/orchestrator-agent.md",
      "dependsOn": [],
      "handoffTargets": [
        "backend-schema-agent",
        "security-agent",
        "mobile-foundation-agent",
        "auth-agent",
        "marketplace-agent",
        "messaging-agent",
        "profile-trust-agent",
        "moderation-admin-agent",
        "platform-release-agent",
        "payment-architecture-agent"
      ],
      "outputs": [
        "Execution plan",
        "Work sequencing",
        "Acceptance gates"
      ]
    },
    {
      "id": "backend-schema-agent",
      "name": "Backend Schema Agent",
      "phase": 1,
      "spec": "agents/specs/backend-schema-agent.md",
      "dependsOn": [
        "orchestrator-agent"
      ],
      "handoffTargets": [
        "security-agent",
        "auth-agent",
        "marketplace-agent",
        "messaging-agent",
        "profile-trust-agent",
        "moderation-admin-agent"
      ],
      "outputs": [
        "Supabase schema",
        "SQL migrations",
        "Typed data contracts"
      ]
    },
    {
      "id": "security-agent",
      "name": "Security Agent",
      "phase": 1,
      "spec": "agents/specs/security-agent.md",
      "dependsOn": [
        "backend-schema-agent"
      ],
      "handoffTargets": [
        "auth-agent",
        "marketplace-agent",
        "messaging-agent",
        "moderation-admin-agent",
        "platform-release-agent"
      ],
      "outputs": [
        "RLS rules",
        "Threat model",
        "Abuse controls",
        "Audit event policy"
      ]
    },
    {
      "id": "mobile-foundation-agent",
      "name": "Mobile Foundation Agent",
      "phase": 1,
      "spec": "agents/specs/mobile-foundation-agent.md",
      "dependsOn": [
        "orchestrator-agent",
        "backend-schema-agent",
        "security-agent"
      ],
      "handoffTargets": [
        "auth-agent",
        "marketplace-agent",
        "messaging-agent",
        "profile-trust-agent",
        "platform-release-agent"
      ],
      "outputs": [
        "App shell",
        "Navigation",
        "Provider setup",
        "Environment wiring"
      ]
    },
    {
      "id": "auth-agent",
      "name": "Auth Agent",
      "phase": 1,
      "spec": "agents/specs/auth-agent.md",
      "dependsOn": [
        "backend-schema-agent",
        "security-agent",
        "mobile-foundation-agent"
      ],
      "handoffTargets": [
        "marketplace-agent",
        "messaging-agent",
        "profile-trust-agent",
        "platform-release-agent"
      ],
      "outputs": [
        "Signup/login flows",
        "Session handling",
        "Route guards",
        "Account bootstrap"
      ]
    },
    {
      "id": "marketplace-agent",
      "name": "Marketplace Agent",
      "phase": 1,
      "spec": "agents/specs/marketplace-agent.md",
      "dependsOn": [
        "backend-schema-agent",
        "security-agent",
        "mobile-foundation-agent",
        "auth-agent"
      ],
      "handoffTargets": [
        "messaging-agent",
        "profile-trust-agent",
        "moderation-admin-agent"
      ],
      "outputs": [
        "Listings flows",
        "Search/filter UX",
        "Image upload integration",
        "Saved items"
      ]
    },
    {
      "id": "messaging-agent",
      "name": "Messaging Agent",
      "phase": 1,
      "spec": "agents/specs/messaging-agent.md",
      "dependsOn": [
        "backend-schema-agent",
        "security-agent",
        "mobile-foundation-agent",
        "auth-agent",
        "marketplace-agent"
      ],
      "handoffTargets": [
        "moderation-admin-agent",
        "platform-release-agent"
      ],
      "outputs": [
        "Conversation model",
        "Realtime subscriptions",
        "Unread state",
        "Message UX"
      ]
    },
    {
      "id": "profile-trust-agent",
      "name": "Profile Trust Agent",
      "phase": 1,
      "spec": "agents/specs/profile-trust-agent.md",
      "dependsOn": [
        "backend-schema-agent",
        "security-agent",
        "mobile-foundation-agent",
        "auth-agent",
        "marketplace-agent"
      ],
      "handoffTargets": [
        "moderation-admin-agent"
      ],
      "outputs": [
        "Profile surfaces",
        "Ratings and reviews",
        "Trust signals",
        "Reporting entrypoints"
      ]
    },
    {
      "id": "moderation-admin-agent",
      "name": "Moderation Admin Agent",
      "phase": 1,
      "spec": "agents/specs/moderation-admin-agent.md",
      "dependsOn": [
        "backend-schema-agent",
        "security-agent",
        "marketplace-agent",
        "messaging-agent",
        "profile-trust-agent"
      ],
      "handoffTargets": [
        "platform-release-agent"
      ],
      "outputs": [
        "Report flows",
        "Moderation statuses",
        "Admin review requirements",
        "Audit hooks"
      ]
    },
    {
      "id": "platform-release-agent",
      "name": "Platform Release Agent",
      "phase": 1,
      "spec": "agents/specs/platform-release-agent.md",
      "dependsOn": [
        "security-agent",
        "mobile-foundation-agent",
        "auth-agent",
        "marketplace-agent",
        "messaging-agent",
        "moderation-admin-agent"
      ],
      "handoffTargets": [
        "payment-architecture-agent"
      ],
      "outputs": [
        "EAS setup",
        "Environment separation",
        "Release checklist",
        "Operational readiness"
      ]
    },
    {
      "id": "payment-architecture-agent",
      "name": "Payment Architecture Agent",
      "phase": 2,
      "spec": "agents/specs/payment-architecture-agent.md",
      "dependsOn": [
        "backend-schema-agent",
        "security-agent",
        "marketplace-agent",
        "platform-release-agent"
      ],
      "handoffTargets": [],
      "outputs": [
        "Deferred payments design",
        "Future Stripe Connect interface",
        "No-op extension points"
      ]
    }
  ]
}
