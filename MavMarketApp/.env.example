EXPO_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Set to "true" for demo runs. Forces the app (swipe feature + feeds)
# to use the local mock data in data/mockData.ts instead of Supabase.
EXPO_PUBLIC_DEMO_MODE=false

# Optional. When set, the pickup map renders a Google Street View image
# of the listing location (falling back to a Google Static Map tile if
# Street View has no imagery there). If unset, the map falls back to a
# live OpenStreetMap tile composite with a centered marker so the card
# still renders a real map. The "Open in Google Maps" link always works.
# The key must have both "Street View Static API" and "Maps Static API"
# enabled in Google Cloud Console for best results.
EXPO_PUBLIC_GOOGLE_MAPS_KEY=
