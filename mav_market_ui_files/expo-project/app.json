{
  "expo": {
    "name": "Mav Market",
    "slug": "mav-market",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "mavmarket",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "backgroundColor": "#0064B1"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "edu.uta.mavmarket"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#0064B1"
      },
      "package": "edu.uta.mavmarket"
    },
    "plugins": [
      "expo-router",
      "expo-font"
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
